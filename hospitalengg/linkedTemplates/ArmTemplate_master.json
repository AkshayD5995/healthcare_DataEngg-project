{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "hospitalengg"
		},
		"SqlServer1source_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'SqlServer1source'"
		},
		"adls_sink_destntn_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'adls_sink_destntn'"
		},
		"AzureKeyVault1_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://onpremwork2.vault.azure.net/"
		},
		"SqlServer1source_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "AKSHAY\\SQLEXPRESS"
		},
		"SqlServer1source_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "hospitaldb"
		},
		"SqlServer1source_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "onpremwork2"
		},
		"adls_sink_destntn_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adls2onpremwork.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "hospitalengg_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"SqlServer1source_password": {
						"value": "[parameters('SqlServer1source_password')]"
					},
					"adls_sink_destntn_accountKey": {
						"value": "[parameters('adls_sink_destntn_accountKey')]"
					},
					"AzureKeyVault1_properties_typeProperties_baseUrl": {
						"value": "[parameters('AzureKeyVault1_properties_typeProperties_baseUrl')]"
					},
					"SqlServer1source_properties_typeProperties_server": {
						"value": "[parameters('SqlServer1source_properties_typeProperties_server')]"
					},
					"SqlServer1source_properties_typeProperties_database": {
						"value": "[parameters('SqlServer1source_properties_typeProperties_database')]"
					},
					"SqlServer1source_properties_typeProperties_userName": {
						"value": "[parameters('SqlServer1source_properties_typeProperties_userName')]"
					},
					"adls_sink_destntn_properties_typeProperties_url": {
						"value": "[parameters('adls_sink_destntn_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}